@model ErrorViewModel
@{
    ViewData["Title"] = "Hata";
}

<div class="flex items-center justify-center min-h-[calc(100vh-16rem)]">
    <div class="w-full max-w-lg">
        <div class="bg-white dark:bg-slate-800 rounded-2xl shadow-xl overflow-hidden border border-slate-100 dark:border-slate-700 border-l-4 border-l-red-500 transition-colors duration-300">

            <div class="px-8 py-6">
                <div class="flex items-start gap-4">
                    <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-red-100 dark:bg-red-900/30 flex items-center justify-center">
                        <svg class="w-6 h-6 text-red-600 dark:text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
                        </svg>
                    </div>
                    <div>
                        <h1 class="text-xl font-bold text-slate-900 dark:text-white mb-1">Bir Hata Oluştu</h1>
                        <p class="text-sm leading-relaxed text-red-700 dark:text-red-300">@Model.ExceptionMessage</p>
                    </div>
                </div>
            </div>

            @if (Model.ShowRequestId)
            {
                <div class="mx-8 border-t border-slate-100 dark:border-slate-700"></div>
                <div class="px-8 py-4">
                    <p class="text-xs text-slate-400 dark:text-slate-500">
                        <span class="font-medium">İşlem Numarası (Request ID):</span>
                        <code class="ml-1.5 px-2 py-1 bg-slate-100 dark:bg-slate-700 rounded-md text-slate-600 dark:text-slate-300 font-mono text-xs">@Model.RequestId</code>
                    </p>
                </div>
            }

            <div class="px-8 py-4 bg-slate-50 dark:bg-slate-900 border-t border-slate-100 dark:border-slate-700 text-center">
                <a href="/"
                   class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl text-sm font-medium border border-slate-300 dark:border-slate-600 text-slate-700 dark:text-slate-300
                          hover:bg-slate-100 dark:hover:bg-slate-700 transition-all duration-200">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                    </svg>
                    Ana Sayfaya Dön
                </a>
            </div>
        </div>
    </div>
</div>
