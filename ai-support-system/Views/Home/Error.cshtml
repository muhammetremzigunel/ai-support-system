@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 text-center">
            <h1 class="text-danger display-4"><i class="bi bi-exclamation-triangle-fill"></i> Oops!</h1>
            <h2 class="mb-4">Something went wrong.</h2>
            
            <div class="alert alert-danger text-start shadow-sm" role="alert">
                <h4 class="alert-heading">Error Details:</h4>
                <hr>
                <p class="mb-0"><strong>@Model.ExceptionMessage</strong></p>
            </div>

            @if (Model.ShowRequestId)
            {
                <p class="text-muted mt-3">
                    <strong>Request ID:</strong> <code>@Model.RequestId</code>
                </p>
            }

            <div class="mt-5">
                <button onclick="history.back()" class="btn btn-primary btn-lg shadow-sm px-4 rounded-pill">
                    <i class="bi bi-arrow-left me-2"></i> Go Back
                </button>
                <a asp-controller="Chat" asp-action="Index" class="btn btn-outline-secondary btn-lg shadow-sm px-4 rounded-pill ms-2">
                    <i class="bi bi-house-door me-2"></i> Home
                </a>
            </div>
        </div>
    </div>
</div>
